// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum roleType {
  ADMIN
  USER
}

enum priorityType {
  LOW
  MEDIUM
  HIGH
}

enum announcementType {
  READ_ONLY
  ASSIGNMENT
}

enum submissionStatus {
  PENDING
  SUBMITTED
  GRADED
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  role         roleType @default(USER)
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  isDeleted    Boolean  @default(false)

  profilePictureUrl String?

  // For email verification
  isEmailVerified    Boolean   @default(false)
  emailVerifyToken   String?
  emailVerifyExpires DateTime?

  // For forgot password
  resetPasswordToken   String?
  resetPasswordExpires DateTime?

  announcements Announcement[]
  readStatus    ReadStatus[]
  submissions   Submission[]

  @@map("users")
}

model Announcement {
  id          String                   @id @default(uuid())
  title       String
  content     String
  priority    priorityType
  type        announcementType         @default(READ_ONLY)
  dueDate     DateTime?
  maxScore    Int?
  readStatus  ReadStatus[]
  attachments AnnouncementAttachment[]
  submissions Submission[]

  // Connecting announcement to user
  createdBy User   @relation(fields: [userId], references: [id])
  userId    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("announcement")
}

model ReadStatus {
  id     String    @id @default(uuid())
  isRead Boolean   @default(false)
  readAt DateTime?

  // Connecting user to readStatus
  user   User   @relation(fields: [userId], references: [id])
  userId String

  // One announcement has many readStatus
  announcement   Announcement @relation(fields: [announcementId], references: [id])
  announcementId String

  // One unique pair of user and announcement with readId
  @@unique([userId, announcementId])
  @@index([userId])
  @@index([announcementId])
  @@map("read_status")
}

model AnnouncementAttachment {
  id         String   @id @default(uuid())
  filename   String
  fileUrl    String
  fileType   String?
  uploadedAt DateTime @default(now())

  // Connecting to Announcement
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  announcementId String

  @@map("announcement_attachment")
}

model Submission {
  id          String           @id @default(uuid())
  status      submissionStatus @default(PENDING)
  grade       Int?
  submittedAt DateTime?

  // Connecting to User
  user   User   @relation(fields: [userId], references: [id])
  userId String

  // Connecting to Announcement
  announcement   Announcement @relation(fields: [announcementId], references: [id])
  announcementId String

  attachments SubmissionAttachment[]

  @@unique([userId, announcementId])
  @@map("submission")
}

model SubmissionAttachment {
  id         String   @id @default(uuid())
  filename   String
  fileUrl    String
  fileType   String?
  uploadedAt DateTime @default(now())

  // Connecting to Submission
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  submissionId String

  @@map("submission_attachment")
}