BASE_URL=your_base_url eg. http://localhost:3000

EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587

EMAIL_USER=your_email
EMAIL_PASS=your_pass

DATABASE_URL=your_database_url
NODE_ENV="development or production"

# For generating auth tokens
ACCESS_SECRET=your_access_secret
REFRESH_SECRET=your_refresh_secret

# For token expiry
ACCESS_EXPIRES_IN=access_token_expires_in eg. 15m
REFRESH_EXPIRES_IN=refresh_token_expires_in eg. 7d

SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

REDIS_URL=your_url_for_redis eg. redis://localhost:6379
